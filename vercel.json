{
  "//": "[PERF FIX 6] Vercel cache headers",
  "headers": [
    {
      "source": "/(.*\\.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(?:jpg|jpeg|png|gif|webp|svg|ico)$",
      "headers": [
        { "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(?:js|css)$",
      "headers": [
        { "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|src/|node_modules/|@.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
