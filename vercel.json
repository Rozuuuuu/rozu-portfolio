{
  "headers": [
    {
      "source": "/(.*\\.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|src/|node_modules/|@.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
